# ── Public site ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://divinegabriel.dev

# Contact form (Resend). Verify divinegabriel.dev as a sender in Resend.
RESEND_API_KEY=

# ── Admin dashboard: content storage (Supabase) ────────────────
# Run supabase/schema.sql once in your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin dashboard: Google login (Auth.js) ────────────────────
# Generate a secret with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Google OAuth credentials (Google Cloud Console → OAuth client).
# Authorized redirect URI: https://divinegabriel.dev/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
